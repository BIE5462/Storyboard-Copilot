{
  "name": "storyboard-copilot",
  "private": true,
  "version": "1.0.17",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "check:type": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format:check": "prettier --check .prettierrc src/test/setup.ts src/features/project/useProjectImageCachePrune.ts src/features/canvas/hooks/useCanvasPersistenceScheduler.ts src/features/canvas/nodes/TextAnnotationMarkdownPreview.tsx",
    "test": "vitest",
    "test:run": "vitest run",
    "tauri": "tauri",
    "sync:version": "node scripts/sync-version.mjs",
    "check:version": "node scripts/check-version.mjs",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check": "npm run check:version && npm run check:type && npm run check:rust && npm run test:rust",
    "release": "node scripts/release.mjs",
    "test:qianhai": "node scripts/test-qianhai-gemini-image-preview.mjs",
    "test:dashscope": "node scripts/test-dashscope-qwen-image.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.75.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@xyflow/react": "^12.5.0",
    "i18next": "^24.2.3",
    "i18next-browser-languagedetector": "^8.0.4",
    "konva": "^9.3.22",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.6",
    "react-i18next": "^15.4.1",
    "react-image-crop": "^11.0.10",
    "react-konva": "^18.2.10",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^11.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.1.0",
    "vitest": "^4.1.5"
  }
}
